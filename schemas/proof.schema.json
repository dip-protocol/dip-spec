{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DIP Merkle Proof",
  "type": "object",
  "required": [
    "artifact_hash",
    "proof_path",
    "root"
  ],
  "additionalProperties": false,
  "properties": {
    "artifact_hash": {
      "type": "string",
      "description": "SHA256 hash of the canonical artifact"
    },
    "proof_path": {
      "type": "array",
      "description": "Merkle proof path from artifact leaf to root",
      "items": {
        "type": "object",
        "required": ["hash", "position"],
        "properties": {
          "hash": {
            "type": "string"
          },
          "position": {
            "type": "string",
            "enum": ["left", "right"]
          }
        },
        "additionalProperties": false
      }
    },
    "root": {
      "type": "string",
      "description": "Merkle root of the decision ledger"
    }
  }
}