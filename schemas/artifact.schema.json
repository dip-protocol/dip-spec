{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DIP Artifact",
  "type": "object",
  "required": [
    "artifact_version",
    "artifact_id",
    "decision",
    "signature"
  ],
  "additionalProperties": false,
  "properties": {
    "artifact_version": {
      "type": "string",
      "enum": ["1"]
    },
    "artifact_id": {
      "type": "string"
    },
    "decision": {
      "$ref": "decision.schema.json"
    },
    "signature": {
      "type": "object",
      "required": [
        "algorithm",
        "public_key",
        "value"
      ],
      "additionalProperties": false,
      "properties": {
        "algorithm": {
          "type": "string",
          "enum": ["ed25519"]
        },
        "public_key": {
          "type": "string"
        },
        "value": {
          "type": "string"
        }
      }
    }
  }
}