{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "protocol_version",
    "decision_id",
    "timestamp",
    "input_hash"
  ],
  "properties": {
    "protocol_version": {
      "type": "string"
    },
    "decision_id": {
      "type": "string"
    },
    "timestamp": {
      "type": "string"
    },
    "input_hash": {
      "type": "string"
    },
    "artifact_hash": {
      "type": "string"
    },
    "signature": {
      "type": "string"
    },
    "public_key": {
      "type": "string"
    }
  }
}