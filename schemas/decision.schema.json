{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DIP Decision Record",
  "type": "object",
  "required": [
    "version",
    "decision_id",
    "timestamp",
    "inputs",
    "outputs",
    "signature"
  ],
  "properties": {
    "version": {
      "type": "string",
      "description": "Protocol version"
    },
    "decision_id": {
      "type": "string",
      "description": "Unique identifier for the decision"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "Time when the decision was produced"
    },
    "inputs": {
      "type": "object",
      "description": "Inputs used to produce the decision"
    },
    "outputs": {
      "type": "object",
      "description": "Decision outputs"
    },
    "metadata": {
      "type": "object",
      "description": "Optional execution metadata"
    },
    "signature": {
      "type": "object",
      "required": ["algorithm", "value"],
      "properties": {
        "algorithm": {
          "type": "string"
        },
        "value": {
          "type": "string"
        }
      }
    }
  }
}