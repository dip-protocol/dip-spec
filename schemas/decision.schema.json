{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DIP Decision Record",
  "type": "object",
  "required": [
    "decision_id",
    "timestamp",
    "inputs",
    "outputs"
  ],
  "additionalProperties": false,
  "properties": {
    "decision_id": {
      "type": "string",
      "description": "Unique identifier for the decision"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "RFC3339 timestamp of decision execution"
    },
    "inputs": {
      "type": "object",
      "description": "Inputs used to compute the decision"
    },
    "outputs": {
      "type": "object",
      "description": "Outputs produced by the decision"
    }
  }
}