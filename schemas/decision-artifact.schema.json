{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "artifact_version",
    "artifact_id",
    "decision",
    "signature"
  ],
  "properties": {
    "artifact_version": {
      "type": "string"
    },
    "artifact_id": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "decision": {
      "type": "object"
    },
    "signature": {
      "type": "object",
      "required": ["algorithm", "public_key", "value"],
      "properties": {
        "algorithm": {
          "type": "string"
        },
        "public_key": {
          "type": "array"
        },
        "value": {
          "type": "array"
        }
      }
    }
  }
}